---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Boyang Fu - Postdoctoral Fellow at Harvard Medical School">
  <div class="container section">
    <div class="hero">
      <div class="hero-content prose">
        <h1>Boyang Fu (付伯阳)</h1>
        <p class="subtitle">
          Postdoctoral Fellow, Department of Biomedical Informatics, Harvard
          Medical School
        </p>
        <p>
          I am a postdoctoral research fellow at <a
            href="https://hms.harvard.edu/"
            target="_blank">Harvard Medical School</a
          >, Department of Biomedical Informatics, advised by Prof. <a
            href="https://zitniklab.hms.harvard.edu/bio/"
            target="_blank">Marinka Zitnik</a
          >. I received my Ph.D. in Computer Science at <a
            href="http://www.ucla.edu/"
            target="_blank">UCLA</a
          >, where I was advised by Prof. <a
            href="http://web.cs.ucla.edu/~sriram/"
            target="_blank">Sriram Sankararaman</a
          >. I earned my Bachelor's Degree (Summa Cum Laude) from <a
            href="https://en.wikipedia.org/wiki/Rutgers_University"
            target="_blank">Rutgers University</a
          > with majors in Computer Science (Highest Honor) and Mathematics. Prior
          to that, I attended <a
            href="https://en.wikipedia.org/wiki/Huazhong_University_of_Science_and_Technology"
            target="_blank">Huazhong University of Science and Technology</a
          > and majored in bioinformatics (Honors Program), and transferred to Rutgers
          University in January 2016.
        </p>
        <p>
          I develop AI/ML methods for complex biological data, with a particular
          focus on human genetics and genomics. My research topics include
          understanding nonlinear genetic variant behavior in high-dimensional
          settings, using multi-omics to decode functional genomics, and
          leveraging genetic variation for causal inference.
        </p><div class="social-links">
          <a
            href="https://scholar.google.com/citations?user=baYulmEAAAAJ&hl=en"
            target="_blank">Google Scholar</a
          >
          <a href="https://github.com/FBoyang" target="_blank">GitHub</a>
          <a href="https://twitter.com/Boyang1995" target="_blank">Twitter</a>
          <a href="https://www.linkedin.com/in/boyang-fu" target="_blank"
            >LinkedIn</a
          >
          <a href="mailto:fbyang1995@gmail.com">Email</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/boyang.jpeg" alt="Boyang Fu" />
      </div>
    </div>

    <div class="interests section">
      <h2>Field of Interests</h2>
      <ul class="tag-list">
        <li>Computational genomics</li>
        <li>Large-scale AI/ML</li>
        <li>Causal inference & Interpretability</li>
      </ul>
    </div>

    <div class="awards section">
      <h2>Selected Awards</h2>
      <ul class="awards-list">
        <li>
          <span class="award-name">UCLA Dissertation Year Fellowship</span>
          <span class="award-detail"
            >$20,000 stipend plus standard tuition and fees</span
          >
          <span class="award-year">[2024-2025]</span>
        </li>
        <li>
          <span class="award-name"
            >Warren Alpert Computational Biology and AI Network Fellow</span
          >
          <span class="award-year">[2024-2025]</span>
        </li>
        <li>
          <span class="award-name"
            ><a
              href="https://www.cs.ucla.edu/the-sriram-lab-achieves-breakthrough-discovery-in-understanding-complex-genetic-and-disease-relationships/"
              target="_blank">Outstanding Research Departmental Nomination</a
            >
          </span>
          <span class="award-year">[2023]</span>
        </li>
        <li>
          <span class="award-name">Outstanding Mentorship Award</span>
          <span class="award-detail"
            >Bruins in Genomics Summer Research Program</span
          >
          <span class="award-year">[2021-2022]</span>
        </li>
        <li>
          <span class="award-name">Graduate Division Fellowship Award</span>
          <span class="award-year">[2020]</span>
        </li>
        <li>
          <span class="award-name">Academic Excellence Scholarship</span>
          <span class="award-year">[2016-2018]</span>
        </li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  .hero {
    display: flex;
    gap: var(--spacing-xl);
    align-items: center;
    margin-bottom: var(--spacing-xl);
  }
  .hero-content {
    flex: 1;
  }
  .hero-content h1 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-sm);
  }
  .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    font-weight: 500;
  }
  .hero-image {
    flex-shrink: 0;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--bg-secondary);
    box-shadow: var(--shadow-lg);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .social-links {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
    flex-wrap: wrap;
  }
  .social-links a {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9rem;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    background-color: var(--bg-tertiary);
    color: var(--text-primary);
    text-decoration: none !important;
  }
  .social-links a:hover {
    background-color: var(--accent-light);
    color: var(--accent-color);
  }
  .tag-list {
    display: flex;
    gap: var(--spacing-md);
    list-style: none;
    padding: 0;
    flex-wrap: wrap;
  }
  .tag-list li {
    background-color: var(--bg-tertiary);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 20px;
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .awards-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  .awards-list li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--bg-tertiary);
  }
  .award-name {
    font-weight: 600;
    color: var(--text-primary);
  }
  .award-name a {
    color: var(--accent-color);
    text-decoration: underline;
    text-decoration-color: var(--accent-light);
    text-underline-offset: 3px;
  }
  .award-detail {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-style: italic;
  }
  .award-year {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-left: auto;
  }
  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
    }
    .social-links,
    .tag-list {
      justify-content: center;
    }
    .award-year {
      margin-left: 0;
    }
  }
</style>
