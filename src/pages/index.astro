---
import Layout from "../layouts/Layout.astro";

const researchAreas = [
  {
    title: "Foundation models for genomics",
    description:
      "I build AI/ML models that learn regulatory information from DNA sequence and genetic variation, with an emphasis on scalable and biologically meaningful representations for human genomics.",
  },
  {
    title: "Perturbation biology",
    description:
      "I study how sequence, regulatory context, and intervention shape transcriptomic responses, aiming to connect DNA-level regulation to cellular state changes under perturbation.",
  },
  {
    title: "Statistical genetics and disease modeling",
    description:
      "I develop methods to characterize nonlinear variant effects, integrate multi-omic data, and improve causal interpretation of complex disease biology.",
  },
];

const focusTags = [
  "Functional genomics",
  "Single-cell perturbation",
  "Foundation models",
  "Statistical genetics",
  "Causal inference",
];
---

<Layout title="Boyang Fu | AI/ML Researcher in Human Genetics and Genomics">
  <div class="container section">
    <section class="hero">
      <div class="hero-content">
        <p class="eyebrow">
          Harvard Medical School · Department of Biomedical Informatics
        </p>
        <h1>Boyang Fu (付伯阳)</h1>
        <p class="subtitle">AI/ML researcher in human genetics and genomics</p>

        <p class="lead">
          I develop machine learning methods for human genetics, functional
          genomics, and perturbation biology. My research focuses on building
          models that connect DNA sequence, genetic variation, and regulatory
          intervention to molecular and cellular phenotypes, and eventually to
          understand human complex diseases.
        </p>

        <p>
          I am a postdoctoral research fellow at
          <a href="https://hms.harvard.edu/" target="_blank"
            >Harvard Medical School</a
          >, advised by Prof.
          <a href="https://zitniklab.hms.harvard.edu/bio/" target="_blank"
            >Marinka Zitnik</a
          >. I received my Ph.D. in Computer Science from
          <a href="http://www.ucla.edu/" target="_blank">UCLA</a>, where I was
          advised by Prof.
          <a href="http://web.cs.ucla.edu/~sriram/" target="_blank"
            >Sriram Sankararaman</a
          >.
        </p>

        <div class="social-links">
          <a
            href="https://scholar.google.com/citations?user=baYulmEAAAAJ&hl=en"
            target="_blank">Google Scholar</a
          >
          <a href="https://github.com/FBoyang" target="_blank">GitHub</a>
          <a href="https://twitter.com/Boyang1995" target="_blank">Twitter</a>
          <a href="https://www.linkedin.com/in/boyang-fu" target="_blank"
            >LinkedIn</a
          >
          <a href="mailto:fbyang1995@gmail.com">Email</a>
        </div>
      </div>

      <div class="hero-image">
        <img src="/images/boyang.jpeg" alt="Boyang Fu" />
      </div>
    </section>

    <section class="section research-overview">
      <h2>Research</h2>
      <p class="section-intro">
        Broadly, I am interested in using AI/ML to understand how human genomes
        encode regulation, how perturbations reshape cellular state, and how
        genetic variation talks to each other to influence complex human traits
        and diseases.
      </p>

      <div class="research-grid">
        {
          researchAreas.map((area) => (
            <article class="research-card">
              <h3>{area.title}</h3>
              <p>{area.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <h2>Current Interests</h2>
      <ul class="tag-list">
        {focusTags.map((tag) => <li>{tag}</li>)}
      </ul>
    </section>
  </div>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 240px;
    gap: var(--spacing-xl);
    align-items: start;
    margin-bottom: var(--spacing-2xl, 3rem);
  }

  .hero-content h1 {
    font-size: 2.6rem;
    line-height: 1.1;
    margin-bottom: var(--spacing-sm);
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-color);
    margin-bottom: var(--spacing-sm);
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    font-weight: 500;
  }

  .lead {
    font-size: 1.12rem;
    line-height: 1.8;
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .hero-image {
    width: 240px;
    height: 240px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--bg-secondary);
    box-shadow: var(--shadow-lg);
    justify-self: end;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .social-links {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .social-links a {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.92rem;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    background-color: var(--bg-tertiary);
    color: var(--text-primary);
    text-decoration: none !important;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .social-links a:hover {
    background-color: var(--accent-light);
    color: var(--accent-color);
    transform: translateY(-1px);
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: var(--spacing-lg);
    color: var(--text-secondary);
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--spacing-lg);
  }

  .research-card {
    background: var(--bg-secondary);
    border: 1px solid var(--bg-tertiary);
    border-radius: var(--radius-lg, 16px);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
  }

  .research-card h3 {
    margin-bottom: var(--spacing-sm);
    font-size: 1.08rem;
    line-height: 1.4;
  }

  .research-card p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .tag-list {
    display: flex;
    gap: var(--spacing-md);
    list-style: none;
    padding: 0;
    flex-wrap: wrap;
    margin: 0;
  }

  .tag-list li {
    background-color: var(--bg-tertiary);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 999px;
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .hero-image {
      justify-self: start;
      width: 200px;
      height: 200px;
    }

    .research-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.2rem;
    }

    .subtitle {
      font-size: 1.08rem;
    }

    .lead {
      font-size: 1.04rem;
    }

    .social-links,
    .tag-list {
      justify-content: flex-start;
    }
  }
</style>
