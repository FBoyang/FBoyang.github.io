<style>
  .teach-section {
    margin-bottom: var(--spacing-xl);
  }
  .teach-section h2 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--bg-tertiary);
  }
  .subtitle {
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: var(--spacing-lg);
  }
  .course-category {
    margin-bottom: var(--spacing-lg);
  }
  .course-category h3 {
    margin-bottom: var(--spacing-md);
  }
  .cat-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
  }
  .cat-badge.math {
    background: #4caf50;
  }
  .cat-badge.stats {
    background: #2196f3;
  }
  .cat-badge.ml {
    background: #9c27b0;
  }
  .course-table {
    overflow-x: auto;
  }
  .course-table table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .course-table th,
  .course-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--bg-tertiary);
  }
  .course-table th {
    background: var(--bg-tertiary);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .course-table tr:hover td {
    background: var(--bg-tertiary);
  }
  .course-table a {
    color: var(--accent-color);
  }
  .eval-link {
    margin-top: var(--spacing-md);
    font-size: 0.9rem;
  }
  @media (max-width: 600px) {
    .course-table th,
    .course-table td {
      padding: 0.5rem;
      font-size: 0.85rem;
    }
  }

  /* Expandable details styling */
  .expandable {
    background: var(--bg-secondary);
    border: 1px solid var(--bg-tertiary);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-md);
  }
  .expandable summary {
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  .expandable summary::before {
    content: "+";
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--accent-color);
    width: 1.5rem;
    text-align: center;
  }
  .expandable[open] summary::before {
    content: "−"; /* minus sign */
  }
  .expandable summary::-webkit-details-marker {
    display: none;
  }
  .expandable-content {
    padding: 0 var(--spacing-lg) var(--spacing-lg) var(--spacing-lg);
  }
</style>
